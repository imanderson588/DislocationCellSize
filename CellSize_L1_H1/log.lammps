fix_modify forcetop energy no
fix_modify forcebottom energy no

reset_timestep 0

# 1. Define the normalized energy variable
variable pe_per_atom equal pe/atoms

# 2. Print the variable to your YAML file
fix extra all print 1 """
- stress: ${sigxy}
- energy: ${pe_per_atom}
""" append energy.yaml screen no title ""


run 0
