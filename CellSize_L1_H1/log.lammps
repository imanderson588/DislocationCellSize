LAMMPS (15 Sep 2022)
# ---------- Initialize Simulation ---------------------
clear
units metal
dimension 3
boundary p p s
atom_style atomic
atom_modify map array
variable sigxy equal ${stress}
variable sigxy equal 0
variable mpa_conversion equal 6.2415e-6


# ---------- Create Atoms ---------------------

read_data EdgeRelaxed.lmp
Reading data file ...
  orthogonal box = (0 0 -4.0802172) to (21.824954 151.20771 75.93192)
  1 by 3 by 2 MPI processor grid
  reading atoms ...
  23952 atoms
  reading velocities ...
  23952 velocities
  read_data CPU = 0.078 seconds

variable surface_area equal $(lx)*$(ly)
variable surface_area equal 21.824953608198121913*$(ly)
variable surface_area equal 21.824953608198121913*151.20771408893131138

variable stress_area equal ${sigxy}*${surface_area}
variable stress_area equal 0*${surface_area}
variable stress_area equal 0*3300.10134519261
variable forceconversion equal ${stress_area}*${mpa_conversion}
variable forceconversion equal 0*${mpa_conversion}
variable forceconversion equal 0*6.2415e-06

variable surface_size equal 5-zlo
variable z_value equal zhi-${surface_size}
variable z_value equal zhi-9.08011629620289



region bottom block EDGE EDGE EDGE EDGE EDGE 5 units box
region top block EDGE EDGE EDGE EDGE ${z_value} EDGE units box
region top block EDGE EDGE EDGE EDGE 66.8517029180322 EDGE units box

group top region top
2812 atoms in group top
group bottom region bottom
2804 atoms in group bottom

variable ntop equal count(top)
variable nbottom equal count(bottom)



variable forcetop equal ${forceconversion}/${ntop}
variable forcetop equal 0/${ntop}
variable forcetop equal 0/2812
variable forcebot equal ${forceconversion}/${nbottom}
variable forcebot equal 0/${nbottom}
variable forcebot equal 0/2804



fix forcetop top addforce  0.0 ${forcetop} 0.0
fix forcetop top addforce  0.0 0 0.0
fix forcebottom bottom addforce  0.0 -${forcebot} 0.0
fix forcebottom bottom addforce  0.0 -0 0.0

fix freeze_top top setforce 0 NULL 0
fix freeze_bottom bottom setforce 0 NULL 0

fix_modify forcetop energy yes
fix_modify forcebottom energy yes

mass 1 180.9479  # Atomic mass of Ta
mass 2 12.011    # Atomic mass of C


# ---------- Define Interatomic Potential ---------------------

pair_style meam
pair_coeff * * ../library.meam Ta C ../TaC.meam Ta C


compute        peratom all pe/atom


thermo 1
thermo_style custom step pe lx ly lz press pxy pyy pzz cellalpha cellbeta cellgamma
min_style cg
minimize 0 1e-5 10000 10000
Neighbor list info ...
  update: every = 1 steps, delay = 0 steps, check = yes
  max neighbors/atom: 2000, page size: 100000
  master list distance cutoff = 5.7
  ghost atom cutoff = 5.7
  binsize = 2.85, bins = 8 54 29
  2 neighbor lists, perpetual/occasional/extra = 2 0 0
  (1) pair meam, perpetual
      attributes: full, newton on
      pair build: full/bin/atomonly
      stencil: full/bin/3d
      bin: standard
  (2) pair meam, perpetual, half/full from (1)
      attributes: half, newton on
      pair build: halffull/newton
      stencil: none
      bin: none
